<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Unlock Your Free Book — Modifya</title>
  <meta name="description" content="Complete one quick step to unlock your free book download." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,600;0,9..144,700;1,9..144,400&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    :root {
      --accent:    #5B4FE8;
      --accent-dk: #4540C4;
      --accent-lt: #EEF0FF;
      --ink:       #0D0D0D;
      --muted:     #6B7280;
      --border:    #E5E7EB;
      --white:     #FFFFFF;
      --green:     #10b981;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Inter', system-ui, sans-serif;
      background: #F6F7FF;
      color: var(--ink);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      -webkit-font-smoothing: antialiased;
    }

    /* ── Header ── */
    .header {
      background: var(--white);
      border-bottom: 1px solid var(--border);
      padding: 16px 24px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .logo-mark {
      width: 32px; height: 32px;
      background: var(--accent);
      color: white;
      border-radius: 8px;
      display: grid;
      place-items: center;
      font-family: 'Fraunces', Georgia, serif;
      font-weight: 700;
      font-size: 1.05rem;
    }
    .logo-text {
      font-family: 'Fraunces', Georgia, serif;
      font-weight: 700;
      font-size: 1.2rem;
      color: var(--ink);
    }
    .header a { text-decoration: none; display: flex; align-items: center; gap: 8px; }

    /* ── Main ── */
    .main {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 48px 20px;
    }

    .unlock-card {
      background: var(--white);
      border-radius: 24px;
      border: 1.5px solid var(--border);
      box-shadow: 0 12px 48px rgba(0,0,0,0.10);
      max-width: 520px;
      width: 100%;
      overflow: hidden;
    }

    .unlock-card__top {
      background: linear-gradient(135deg, #4540C4 0%, #5B4FE8 60%, #7c6ef0 100%);
      padding: 40px 36px 36px;
      text-align: center;
    }
    .unlock-card__icon { font-size: 3rem; margin-bottom: 16px; }
    .unlock-card__title {
      font-family: 'Fraunces', Georgia, serif;
      font-size: 1.7rem;
      font-weight: 700;
      color: white;
      line-height: 1.2;
      margin-bottom: 10px;
    }
    .unlock-card__title em { font-style: italic; }
    .unlock-card__sub {
      font-size: 0.95rem;
      color: rgba(255,255,255,0.8);
      line-height: 1.6;
    }

    .unlock-card__body {
      padding: 36px;
    }

    /* Steps */
    .steps { display: flex; flex-direction: column; gap: 18px; margin-bottom: 32px; }
    .step {
      display: flex;
      align-items: flex-start;
      gap: 14px;
    }
    .step__num {
      width: 32px; height: 32px;
      background: var(--accent-lt);
      color: var(--accent);
      border-radius: 50%;
      display: grid;
      place-items: center;
      font-weight: 700;
      font-size: 0.88rem;
      flex-shrink: 0;
    }
    .step__text { padding-top: 5px; }
    .step__title { font-weight: 600; font-size: 0.95rem; margin-bottom: 2px; }
    .step__desc { font-size: 0.84rem; color: var(--muted); line-height: 1.5; }

    /* CPA Locker Placeholder */
    .locker-placeholder {
      background: var(--accent-lt);
      border: 2px dashed rgba(91,79,232,0.3);
      border-radius: 14px;
      padding: 28px 24px;
      text-align: center;
      margin-bottom: 24px;
    }
    .locker-placeholder__label {
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 10px;
    }
    .locker-placeholder__title {
      font-family: 'Fraunces', Georgia, serif;
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--ink);
      margin-bottom: 8px;
    }
    .locker-placeholder__desc {
      font-size: 0.84rem;
      color: var(--muted);
      line-height: 1.55;
      margin-bottom: 18px;
    }

    /* The CPA unlock button */
    .btn-unlock {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: var(--accent);
      color: white;
      padding: 14px 32px;
      border-radius: 100px;
      font-family: 'Inter', sans-serif;
      font-size: 1rem;
      font-weight: 700;
      border: none;
      cursor: pointer;
      text-decoration: none;
      box-shadow: 0 8px 24px rgba(91,79,232,0.30);
      transition: background 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
      width: 100%;
      justify-content: center;
    }
    .btn-unlock:hover {
      background: var(--accent-dk);
      transform: translateY(-1px);
      box-shadow: 0 12px 32px rgba(91,79,232,0.40);
    }

    .trust-row {
      display: flex;
      justify-content: center;
      gap: 20px;
      margin-top: 18px;
      flex-wrap: wrap;
    }
    .trust-item {
      font-size: 0.78rem;
      color: var(--muted);
      display: flex;
      align-items: center;
      gap: 5px;
    }
    .trust-item span { color: var(--green); font-size: 0.9rem; }

    /* ── Footer ── */
    .footer {
      background: var(--ink);
      color: rgba(255,255,255,0.5);
      text-align: center;
      padding: 24px 20px;
      font-size: 0.82rem;
    }
    .footer a {
      color: rgba(255,255,255,0.65);
      text-decoration: underline;
      margin-inline: 8px;
    }
    .footer-links { margin-top: 8px; }

    /* ── Dev note ── */
    .dev-note {
      background: #fffbe6;
      border: 1px solid #f59e0b;
      border-radius: 10px;
      padding: 14px 18px;
      font-size: 0.82rem;
      color: #92400e;
      line-height: 1.55;
      margin-top: 20px;
    }
    .dev-note strong { font-weight: 700; }

    @media (max-width: 520px) {
      .unlock-card__top { padding: 32px 24px 28px; }
      .unlock-card__body { padding: 24px 20px; }
      .trust-row { gap: 12px; }
    }
  </style>
</head>
<body>

  <header class="header">
    <a href="index.html">
      <div class="logo-mark">M</div>
      <span class="logo-text">Modifya</span>
    </a>
  </header>

  <main class="main">
    <div class="unlock-card">

      <div class="unlock-card__top">
        <div class="unlock-card__icon">🔓</div>
        <h1 class="unlock-card__title">Almost there!<br /><em>Unlock Your Free Book</em></h1>
        <p class="unlock-card__sub">Complete one quick step below to get instant access to your download.</p>
      </div>

      <div class="unlock-card__body">

        <div class="steps">
          <div class="step">
            <div class="step__num">1</div>
            <div class="step__text">
              <p class="step__title">Complete the offer below</p>
              <p class="step__desc">Takes less than 60 seconds. No payment required.</p>
            </div>
          </div>
          <div class="step">
            <div class="step__num">2</div>
            <div class="step__text">
              <p class="step__title">Access is unlocked instantly</p>
              <p class="step__desc">Your download link will appear as soon as you complete the step.</p>
            </div>
          </div>
          <div class="step">
            <div class="step__num">3</div>
            <div class="step__text">
              <p class="step__title">Start reading today</p>
              <p class="step__desc">Download the book in PDF format and start your journey.</p>
            </div>
          </div>
        </div>

        <!-- ══ CPA CONTENT LOCKER ZONE ══════════════════════════════ -->
        <!-- Replace this entire div with your AdBlueMedia locker code  -->
        <div class="locker-placeholder">
          <p class="locker-placeholder__label">🔒 Content Locker</p>
          <h2 class="locker-placeholder__title">Complete one offer to unlock</h2>
          <p class="locker-placeholder__desc">
            This area is reserved for your <strong>AdBlueMedia CPA Content Locker</strong>.<br />
            Paste your locker script/embed code here to activate the unlock flow.
          </p>
          <!-- Paste AdBlueMedia locker embed here ↓ -->
          <a href="#" class="btn-unlock" id="unlockBtn">
            🎁 &nbsp;Unlock Free Access
          </a>
        </div>
        <!-- ══ END CPA LOCKER ZONE ═══════════════════════════════════ -->

        <div class="trust-row">
          <span class="trust-item"><span>✓</span> 100% Free</span>
          <span class="trust-item"><span>✓</span> Instant Access</span>
          <span class="trust-item"><span>✓</span> No Card Required</span>
          <span class="trust-item"><span>✓</span> PDF Download</span>
        </div>

        <div class="dev-note">
          <strong>⚙️ Developer Note:</strong> Replace the locker placeholder above with your
          <a href="https://adblue.media" target="_blank" rel="noopener">AdBlueMedia</a>
          content locker embed code. Once the user completes the CPA offer, redirect them to the
          actual book PDF URL using the locker's success callback.
        </div>

      </div>
    </div>
  </main>

  <footer class="footer">
    <p>© 2025 Modifya — All rights reserved.</p>
    <div class="footer-links">
      <a href="index.html">Home</a>
      <a href="#">Privacy Policy</a>
      <a href="#">Terms of Service</a>
    </div>
  </footer>

  <script>
    // Placeholder click handler — replace with AdBlueMedia locker logic
    document.getElementById('unlockBtn').addEventListener('click', function(e) {
      e.preventDefault();
      alert('⚙️ CPA Locker not configured yet.\n\nReplace this button with your AdBlueMedia embed code.');
    });
  </script>

</body>
</html>